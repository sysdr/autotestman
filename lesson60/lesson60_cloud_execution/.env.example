
# .env.example — Copy to .env and adjust. NEVER commit .env to git.
#
# Default: dry-run stub driver (pytest passes without BrowserStack).
APPIUM_MODE=dry
#
# Real BrowserStack cloud session:
# APPIUM_MODE=cloud
# BS_USERNAME=your_real_username
# BS_ACCESS_KEY=your_real_access_key
BS_USERNAME=your_browserstack_username
BS_ACCESS_KEY=your_browserstack_access_key_here
BS_APP_URL=bs://c700ce60cf13ae8ed97705a55b8e022f13c5827e
BS_DEVICE=Samsung Galaxy S21
BS_OS_VERSION=11.0
BS_BUILD=UQAP_CI
#
# --- Local: Pixel 7a emulator + Appium 2 (same UI tests as cloud lesson, no BrowserStack) ---
# 1) Android Studio → Device Manager → create/start Pixel 7a AVD.
# 2) Install the SAME Android sample app as the lesson (login + Dashboard UI), .apk on disk.
#    Official BrowserStack sample APK: https://www.browserstack.com/docs/app-automate/appium/getting-started/python
#    (section "Sample app" / upload — use the Android .apk locally).
# 3) Terminal: appium  (default http://127.0.0.1:4723)
# 4) Set:
# APPIUM_MODE=local
# LOCAL_APPIUM_URL=http://127.0.0.1:4723
# LOCAL_APK_PATH=C:\\Users\\YOU\\Downloads\\SampleApp.apk
# First emulator is usually emulator-5554 (check: adb devices):
# LOCAL_UDID=emulator-5554
# LOCAL_DEVICE_NAME=Pixel 7a
# Pre-flight: python scripts/check_lesson60_local.py
